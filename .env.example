# HybridSecure environment variables
# Copy this file to .env and fill in your own values.

# Server
PORT=8080
APP_URL=http://localhost:8080

# Google OAuth 2.0 (Web application client)
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret

# Google Service Account (used for Sheets API)
SERVICE_ACCOUNT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com
SERVICE_ACCOUNT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY_CONTENT\n-----END PRIVATE KEY-----\n"

# Google Sheets
# Spreadsheet must contain tabs:
# USERS, MESSAGES, USERS_KEYS, CHAT_SECRETS,
# PLAINTEXT_MESSAGES_LOG, ENCRYPTED_MESSAGES, NETWORK_TRAFFIC
SPREADSHEET_ID=your_spreadsheet_id
